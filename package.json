{
  "name": "underleaf-workspace",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @underleaf/web\" \"npm run dev -w @underleaf/server\"",
    "build": "npm run build -w @underleaf/web",
    "deploy": "npm run deploy -w @underleaf/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
